{
  "name": "gql2sql",
  "version": "3.0.0",
  "description": "A modern GraphQL-to-SQL teaching showcase built with Apollo Server, Prisma, TypeScript, and SQLite.",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "build": "npm run db:generate && npm run codegen && tsc -p tsconfig.json",
    "typecheck": "npm run db:generate && npm run codegen && tsc --noEmit",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test": "npm run db:generate && npm run codegen && vitest run",
    "test:watch": "npm run db:generate && npm run codegen && vitest",
    "codegen": "graphql-codegen --config codegen.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:reset": "prisma migrate reset --force",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio"
  },
  "keywords": [
    "sql",
    "graphql",
    "nodejs",
    "typescript",
    "prisma",
    "apollo"
  ],
  "author": "Patrick Metzdorf <patrick.metzdorf@hey.com>",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@apollo/server": "^5.0.0",
    "@as-integrations/express5": "^1.0.0",
    "@graphql-tools/load-files": "^7.0.0",
    "@graphql-tools/merge": "^9.0.0",
    "@prisma/adapter-better-sqlite3": "^7.0.0",
    "@prisma/client": "^7.0.0",
    "dotenv": "^16.0.0",
    "express": "^5.0.0",
    "graphql": "^16.11.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@graphql-codegen/cli": "^5.0.0",
    "@graphql-codegen/typescript": "^4.0.0",
    "@graphql-codegen/typescript-resolvers": "^4.0.0",
    "@types/express": "^5.0.0",
    "@types/node": "^24.0.0",
    "@types/supertest": "^6.0.0",
    "prisma": "^7.0.0",
    "supertest": "^7.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^3.0.0"
  }
}
